---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug"

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const last_posts = posts.slice(0, 3);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">I'm Christina (Zixi) Li</div>
    <div class="text-3xl py-3 font-bold">Phd Student @ University of Waterloo</div>
    <div class="py-2">
      <text class="text-lg">
      I am a human–computer interaction researcher exploring how AI-mediated, multi-modal interfaces can support everyday health, communication, and aging. My work sits at the intersection of conversational systems, lightweight visualisations, and mobile experiences, with an emphasis on accessibility, privacy, and respectful, boundary-aware design for aging populations and their families, caregivers. I’m interested in problems that scale—turning real-world signals into simple, helpful interactions, evaluating user trust and understanding, and translating insights into deployable products. I previously served as a research assistant with the Relational Agents Group at Northeastern University. I am now a PhD student in Computer Science at the University of Waterloo, supervised by <i> Dr. Jim Wallace </i> and <i>Dr. Keiko Katsuragawa</i>.
      </text>
    </div>
    <br />
  <div>
    <div class="text-3xl w-full font-bold mb-2">My lastest projects {"</>"}</div>
  </div>

  <HorizontalCard
    title="(Re-) Defining Boundaries in Informal Care: An Interview Study on the Perspectives of Aging Parents and Adult Children"
    img="/IH.webp"
    desc="This interview study examines how aging parents and adult children communicate and negotiate boundaries in informal care. Through interviews and reflexive thematic analysis, the paper shows that boundaries are flexible, relational practices that can support care, manage family dynamics, and adapt to changing needs. It offers design considerations for aging-in-place technologies that support autonomy, flexible boundary-setting, and meaningful family connection."
    url="https://doi.org/10.1145/3822595"
    badge="ACM HEALTH"
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Using Generative AI to Balance Privacy and Awareness in Inter-generational Caregiving"
    img="/teaser.webp"
    desc="This project explores how abstract AI-generated visual summaries can support connection between older adults and adult children while respecting privacy, autonomy, and family boundaries. Through experience sampling and interviews the study investigates what everyday details families want to share, what they prefer to hide, and where AI summaries may become meaningful, incomplete, or inappropriate."
    url="https://doi.org/10.48550/arXiv.2606.05055"
    badge=" Poster at GI 2026"
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Pain Assessment"
    img="/PAS.webp"
    desc="Embodied Conversational Agents—animated characters that simulate face-to-face conversation—can provide a medium for automated pain assessment in which multimodal pain narratives are elicited, clarifed, and grounded. These agents can also use facial displays and nonverbal behavior to provide simulated empathic responses to help patients feel understood."
    url="https://dl.acm.org/doi/pdf/10.1145/3610661.3617132"
    badge="ICMI '23 Companion"
  />
  <div class="divider my-0"></div>

    <HorizontalCard
    title="COVID Vaccination"
    img="/SCC.webp"
    desc="Participated in  developing a smartphone-based conversational agent intervention to promote COVID-19 vaccination among members of predominately African American churches. The intervention is based on the stages-of-change (transtheoretical) model, incoporating elements of motivational interviewing for those who are vaccine hesistant. The agent and its messaging are culturally tailored for members of the churches we are working with, and addresses misconceptions and myths about COVID-19 and available vaccines. For users who are fully-vaccinated, the agent counsels them on how to talk to their friends and family about vaccination."
    url="https://relationalagents.com/project/covid/index.html"
    badge="Past Project"
  />
 
  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.slug)}
          target="_self"
          badge={post.data.badge}
        />
        <div class="divider my-0" />
      </>
    ))
  }
</BaseLayout>
