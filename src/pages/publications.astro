---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Publications / Preprints</div>
  </div>

  <HorizontalCard
    title="Using Generative AI to Balance Privacy and Awareness in Inter-generational Caregiving"
    img="/teaser.webp"
    desc="This project explores how abstract AI-generated visual summaries can support connection between older adults and adult children while respecting privacy, autonomy, and family boundaries. Through experience sampling and interviews the study investigates what everyday details families want to share, what they prefer to hide, and where AI summaries may become meaningful, incomplete, or inappropriate."
    url="https://doi.org/10.48550/arXiv.2606.05055"
    badge=" Poster at GI 2026"
  />
  <div class="divider my-0"></div>

  <HorizontalCard
    title="Pain Assessment"
    img="/PAS.webp"
    desc="Embodied Conversational Agents—animated characters that simulate face-to-face conversation—can provide a medium for automated pain assessment in which multimodal pain narratives are elicited, clarifed, and grounded. These agents can also use facial displays and nonverbal behavior to provide simulated empathic responses to help patients feel understood."
    url="https://dl.acm.org/doi/pdf/10.1145/3610661.3617132"
    badge="ICMI '23 Companion"
  />
  <div class="divider my-0"></div>
  
</BaseLayout>
